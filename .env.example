# Use a unique slug per stack. It is used for Compose resource names and Traefik router names.
STACK_NAME=pcs

# Any *.localhost domain resolves to 127.0.0.1 without editing /etc/hosts.
DOMAIN=pcs.localhost
PROXY_NETWORK=local-proxy
TZ=America/Sao_Paulo
HOST_UID=1000
HOST_GID=1000
OLS_ADMIN_PORT=7080

DB_NAME=wordpress_db
DB_USER=db_user
DB_PASSWORD=db_password
DB_ROOT_PASSWORD=db_root_password

# Optional. Leave blank to default to http://${DOMAIN}.
WP_HOME=
WP_SITE_TITLE=WordPress
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=password
WP_ADMIN_EMAIL=admin@example.com

# Optional: https://api.wordpress.org/secret-key/1.1/salt/
WP_CACHE_KEY_SALT=
